# Copy to .env and fill in from your app at https://developers.tiktok.com (Manage apps)
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=

# Must EXACTLY match a Redirect URI registered on your app (HTTPS required).
# For the paste-the-code flow, https://localhost/callback works fine.
TIKTOK_REDIRECT_URI=https://localhost/callback
